<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>Tax Invoice</title>
        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            @page {
                size: A4;
                margin: 8mm;
            }

            body {
                font-family: Arial, Helvetica, sans-serif;
                background: #f3f4f6;
                padding: 10px;
                color: #000;
            }

            .invoice {
                width: 210mm;
                min-height: 297mm;
                margin: auto;
                background: #fff;
                border: 2px solid #000;
                border-radius: 14px;
                overflow: hidden;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            td,
            th {
                border: 1px solid #000;
                padding: 3px 5px;
                font-size: 11.5px;
                vertical-align: top;
            }

            .center {
                text-align: center;
            }
            .right {
                text-align: right;
            }
            .bold {
                font-weight: bold;
            }

            /* ── HEADER ───────────────────── */
            .invoice-header {
                padding: 8px 12px 6px;
                border-bottom: 1px solid #000;
            }

            .top-line {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
            }

            .logo-cell {
                width: 100px;
                min-height: 50px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .logo {
                max-width: 90px;
                max-height: 60px;
            }

            .tax-title {
                background: #000;
                color: #fff;
                padding: 3px 16px;
                border-radius: 4px;
                font-size: 17px;
                font-weight: bold;
                letter-spacing: 1px;
            }

            .mobile {
                text-align: right;
                font-size: 11.5px;
                font-weight: bold;
                line-height: 1.5;
                min-width: 100px;
            }

            .company {
                text-align: center;
                margin-top: 3px;
            }

            .company h1 {
                color: #c1121f;
                font-size: 34px;
                letter-spacing: 1px;
                font-weight: 900;
                line-height: 1;
            }

            .company h2 {
                font-size: 14px;
                margin-top: 1px;
                font-weight: 600;
            }

            .company p {
                font-size: 11px;
                line-height: 1.35;
                margin-top: 1px;
            }

            /* ── GST ROW ───────────────────── */
            .gst-row td {
                font-weight: bold;
                text-align: center;
                font-size: 12px;
                padding: 4px 6px;
            }

            /* ── PARTY + META ──────────────────────── */
            .party-section td {
                vertical-align: top;
                padding: 6px 7px;
            }

            .party-box {
                width: 52%;
            }
            .meta-box {
                width: 48%;
            }

            .meta-table {
                width: 100%;
                border-collapse: collapse;
            }

            .meta-table td {
                height: 26px;
                font-size: 11px;
                padding: 2px 5px;
                vertical-align: middle;
            }

            /* ← key fix: was 40%, now 30% so value cells get more room */
            .meta-label {
                width: 30%;
                font-weight: bold;
                white-space: nowrap;
            }

            /* value cells — explicit widths so nothing gets squeezed */
            .meta-val-main {
                width: 25%;
            } /* invoice no / challan no / po no */
            .meta-val-date {
                width: 45%;
            } /* date value — wider */

            /* ── ITEMS TABLE ───────────────── */
            .items-table {
                width: 100%;
                border-collapse: collapse;
            }

            .items-table th {
                text-align: center;
                font-size: 11.5px;
                font-weight: bold;
                padding: 4px 3px;
            }

            .items-table td {
                font-size: 11.5px;
                padding: 3px 4px;
            }

            .sr {
                width: 5%;
                text-align: center;
            }
            .desc {
                width: 45%;
            }
            .hsn {
                width: 13%;
                text-align: center;
            }
            .qty {
                width: 9%;
                text-align: center;
            }
            .rate {
                width: 14%;
                text-align: right;
            }
            .amount {
                width: 14%;
                text-align: right;
            }

            .item-row td {
                height: 22px;
            }
            .empty-row td {
                height: 22px;
            }

            /* ── BOTTOM ────────────────────── */
            .words-row td {
                vertical-align: middle;
                font-size: 11.5px;
                padding: 5px 7px;
            }

            .bank-inner {
                width: 100%;
                border-collapse: collapse;
            }

            .bank-inner td {
                border: none;
                font-size: 11px;
                padding: 4px 6px;
                vertical-align: middle;
            }

            .bank-title {
                writing-mode: vertical-rl;
                transform: rotate(180deg);
                text-align: center;
                font-weight: bold;
                width: 24px;
                font-size: 10px;
                border-right: 1px solid #000;
                padding: 5px 3px;
            }

            .bank-content {
                line-height: 1.7;
                padding: 5px 8px;
            }

            .total-label {
                font-weight: bold;
            }

            .grand-row td {
                font-weight: bold;
                font-size: 13px;
                padding: 5px 7px;
            }

            /* ── DECLARATION ───────────────── */
            .declaration {
                font-size: 9px;
                line-height: 1.4;
                padding: 5px 7px;
                vertical-align: middle;
            }

            .sign-box {
                text-align: center;
                vertical-align: bottom;
                padding: 0;
            }

            .sign-top {
                font-size: 11.5px;
                font-weight: bold;
                padding: 5px;
                border-bottom: 1px solid #000;
            }

            .sign-space {
                height: 48px;
            }

            .sign-label {
                border-top: 1px solid #000;
                padding: 5px 4px;
                text-align: center;
                font-weight: bold;
                font-size: 11px;
            }

            @media print {
                body {
                    background: #fff;
                    padding: 0;
                }
                .invoice {
                    border-radius: 14px;
                }
            }
        </style>
    </head>
    <body>
        <div class="invoice">

            <!-- ── HEADER ──────────────────────────────── -->
            <div class="invoice-header">
                <div class="top-line">
                    <div class="logo-cell">
                        {{#if seller.logo}}
                            <img
                                src="{{seller.logo}}"
                                class="logo"
                                alt="logo"
                            />
                        {{/if}}
                    </div>
                    <div class="tax-title">TAX INVOICE</div>
                    <div class="mobile">
                        Mob.:
                        {{seller.mobile1}}<br />
                        {{seller.mobile2}}
                    </div>
                </div>
                <div class="company">
                    <h1>{{seller.companyName}}</h1>
                    <h2>{{seller.tagline}}</h2>
                    <p>Office : {{seller.officeAddress}}</p>
                    <p>Works : {{seller.worksAddress}}</p>
                    <p>Email : {{seller.email}}</p>
                </div>
            </div>

            <!-- ── GST ROW ──────────────────────────────── -->
            <table>
                <tr class="gst-row">
                    <td>GSTIN : {{seller.gstin}}</td>
                    <td>STATE : {{seller.state}}</td>
                    <td>STATE CODE : {{seller.stateCode}}</td>
                </tr>
            </table>

            <!-- ── PARTY + META ─────────────────────────── -->
            <table class="party-section">
                <tr>
                    <td class="party-box">
                        <div class="bold">To,</div>
                        <div style="margin-top:3px">M/s.
                            {{buyer.companyName}}</div>
                        <div style="margin-top:6px">{{buyer.address}}</div>
                        <div style="margin-top:10px">
                            <span class="bold">GSTIN :</span>
                            {{buyer.gstin}}
                        </div>
                    </td>
                    <td class="meta-box" style="padding:0">
                        <table class="meta-table">
                            <tr>
                                <td class="meta-label">Invoice No. :</td>
                                <td
                                    class="meta-val-main"
                                >{{invoiceMeta.invoiceNo}}</td>
                                <td class="meta-label">Date :</td>
                                <td
                                    class="meta-val-date"
                                >{{invoiceMeta.invoiceDate}}</td>
                            </tr>
                            {{#if invoiceMeta.challanNo}}
                                <tr>
                                    <td class="meta-label">Challan No. :</td>
                                    <td
                                        class="meta-val-main"
                                    >{{invoiceMeta.challanNo}}</td>
                                    <td class="meta-label">Date :</td>
                                    <td
                                        class="meta-val-date"
                                    >{{invoiceMeta.challanDate}}</td>
                                </tr>
                            {{/if}}
                            {{#if invoiceMeta.poNo}}
                                <tr>
                                    <td class="meta-label">P.O. No. :</td>
                                    <td
                                        class="meta-val-main"
                                    >{{invoiceMeta.poNo}}</td>
                                    <td class="meta-label">Date :</td>
                                    <td
                                        class="meta-val-date"
                                    >{{invoiceMeta.poDate}}</td>
                                </tr>
                            {{/if}}
                            {{#if invoiceMeta.vendorCode}}
                                <tr>
                                    <td class="meta-label">Vendor Code :</td>
                                    <td
                                        colspan="3"
                                    >{{invoiceMeta.vendorCode}}</td>
                                </tr>
                            {{/if}}
                        </table>
                    </td>
                </tr>
            </table>

            <!-- ── ITEMS ────────────────────────────────── -->
            <table class="items-table">
                <thead>
                    <tr>
                        <th class="sr">Sr.<br />No.</th>
                        <th class="desc">Description of Goods</th>
                        <th class="hsn">HSN/SAC</th>
                        <th class="qty">Qty.</th>
                        <th class="rate">Rate</th>
                        <th class="amount">Amount Rs.</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each items}}
                        <tr class="item-row">
                            <td class="center">{{no}}</td>
                            <td>{{description}}</td>
                            <td class="center">{{hsnCode}}</td>
                            <td class="center">{{qty}}</td>
                            <td class="right">{{rate}}</td>
                            <td class="right">{{total}}</td>
                        </tr>
                    {{/each}}

                    {{#each emptyRows}}
                        <tr class="empty-row">
                            <td>&nbsp;</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    {{/each}}
                </tbody>
            </table>

            <!--
    ── BOTTOM SECTION ──────────────────────────
    Column layout (4 cols):
    Col A: 52% — bank details / declaration
    Col B: 16% — vehicle no / receiver sign
    Col C: 16% — total labels
    Col D: 16% — total values
-->

            <table>

                <colgroup>
                    <col style="width:52%" />
                    <col style="width:16%" />
                    <col style="width:16%" />
                    <col style="width:16%" />
                </colgroup>
                <!-- Row 1: Rs in words + Sub Total -->
                <tr class="words-row">
                    <td colspan="2" style="width:68%">
                        <span class="bold">Rs. in words :</span>
                        {{totals.grandTotalWords}}
                    </td>

                    <td class="total-label">Sub Total</td>
                    <td style="text-align:right">
                        {{totals.subtotal}}
                    </td>
                </tr>

                <!-- Row 2: Bank (rowspan 4) | Vehicle No (rowspan 4 ← was 2) | CGST -->
                <tr>
                    <td
                        rowspan="4"
                        style="width:52%;padding:0;vertical-align:top"
                    >
                        <table class="bank-inner">
                            <tr>
                                <td class="bank-title">BANK DETAILS</td>
                                <td class="bank-content">
                                    <span class="bold">Bank Name :</span>
                                    {{bankDetails.bankName}}<br />
                                    <span class="bold">Account No. :</span>
                                    {{bankDetails.accountNo}}<br />
                                    <span class="bold">Branch :</span>
                                    {{bankDetails.branch}}<br />
                                    <span class="bold">IFSC Code :</span>
                                    {{bankDetails.ifsc}}<br />
                                    <span class="bold">Email :</span>
                                    {{seller.email}}
                                </td>
                            </tr>
                        </table>
                    </td>

                    <!-- ← rowspan="4" now covers all 4 rows, no empty block below -->
                    <td
                        rowspan="4"
                        style="width:16%;text-align:center;font-weight:bold;
                   font-size:11.5px;vertical-align:middle;padding:8px 4px"
                    >
                        Vehicle No.<br /><br />
                        {{shippingDetails}}
                    </td>

                    <td class="total-label">CGST @ {{totals.cgstRate}}%</td>
                    <td style="text-align:right">{{totals.cgst}}</td>
                </tr>

                <!-- Row 3: SGST -->
                <tr>
                    <td class="total-label">SGST @ {{totals.sgstRate}}%</td>
                    <td style="text-align:right">{{totals.sgst}}</td>
                </tr>

                <!-- Row 4: Round Off -->
                <tr>
                    <td class="total-label">Round Off</td>
                    <td style="text-align:right">{{totals.roundOff}}</td>
                </tr>

                <!-- Row 5: Grand Total — no empty <td> needed anymore -->
                <tr class="grand-row">
                    <td class="total-label">
                        Grand Total
                        <span
                            style="font-size:9px;font-weight:normal"
                        >&nbsp;E.&amp;O.E.</span>
                    </td>
                    <td
                        style="text-align:right;font-weight:bold;font-size:13px"
                    >
                        {{totals.grandTotal}}
                    </td>
                </tr>
            </table>

            <!--
    ── DECLARATION ROW ─────────────────────────
    3 cols: Declaration | Receiver's Sign | For Company Sign
-->
            <table>
                <tr>
                    <!-- Col 1: Declaration (52%) -->
                    <td style="width:52%" class="declaration">
                        I / We hereby certify that my / our registration
                        certificate under the GST Act, 2017 is in force on the
                        date on which the supply of the goods specified in this
                        tax invoice is made by me / us and that the transaction
                        of supplies covered by this tax invoice has been
                        effected by me / us and it shall be accounted for in the
                        turnover of supplies while filing of return and the due
                        tax, if any, payable on the supplies has been paid or
                        shall be paid.
                    </td>

                    <!-- Col 2: Receiver's Signature (16%) — same width as vehicle no -->
                    <td style="width:16%;padding:0" class="sign-box">
                        <div class="sign-space"></div>
                        <div class="sign-label">Receiver's<br />Signature</div>
                    </td>

                    <!-- Col 3: For Company + Authorised Sign (32%) -->
                    <td style="width:32%;padding:0" class="sign-box">
                        <div class="sign-top">For {{seller.companyName}}</div>
                        <div class="sign-space"></div>
                        <div class="sign-label">Authorised Signatory</div>
                    </td>
                </tr>
            </table>

            <table>
                <tr>
                    <td
                        style="
                text-align:center;
                font-size:8.5px;
                padding:6px;
                color:#444;
            "
                    >
                        This is a computer-generated invoice based on the
                        supplied transaction data. In case of any discrepancy,
                        please contact the authorised representative of
                        {{seller.companyName}}.

                    </td>
                </tr>
            </table>

        </div>
    </body>
</html>